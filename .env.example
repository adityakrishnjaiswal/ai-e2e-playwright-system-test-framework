# Environment Variables for Secure Configuration
# Copy this file to .env and update with your actual values

# UI Configuration
BASE_URL=https://the-internet.herokuapp.com
BROWSER=chromium
HEADLESS=true

# API Configuration - External Services
API_BASE_URL=https://jsonplaceholder.typicode.com
AUTH_API_BASE_URL=https://jsonplaceholder.typicode.com
STORE_API_BASE_URL=https://jsonplaceholder.typicode.com

# Test Credentials - Store securely, never commit to version control
TEST_USER_EMAIL=your_test_user_email@example.com
TEST_USER_PASSWORD=your_secure_test_password
INVALID_USER_EMAIL=invalid@example.com
INVALID_USER_PASSWORD=wrongpassword

# UI Test Credentials
VALID_USERNAME=your_valid_ui_username
VALID_PASSWORD=your_valid_ui_password
INVALID_USERNAME=invalid
INVALID_PASSWORD=invalid

# API Keys and Tokens (for services that require them)
# Get these from respective service providers
REQRES_API_KEY=your_reqres_api_key_here
FAKESTORE_API_KEY=your_fakestore_api_key_here

# Test Environment Settings
ENVIRONMENT=test
LOG_LEVEL=INFO

# Timeouts and Retry Settings
API_TIMEOUT=10
MAX_RETRIES=3

# Security Notes:
# - Never commit actual secrets to version control
# - Use environment-specific .env files (.env.prod, .env.staging)
# - Consider using cloud secret managers (AWS Secrets Manager, Azure Key Vault, etc.)
# - Rotate credentials regularly
# - Use principle of least privilege